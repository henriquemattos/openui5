{
	"sap.app": {
		"id": "cardsdemo.navigationAction.timeline",
		"type": "card"
	},
	"sap.card": {
		"type": "Timeline",
		"header": {
			"title": "Upcoming Activities",
			"subtitle": "For Today"
		},
		"content": {
			"data": {
				"json": [
					{
						"Title": "Weekly sync: Marketplace / Design Stream",
						"Description": "MRR WDF18 C3.2(GLASSBOX)",
						"Icon": "sap-icon://appointment-2",
						"Time": "10:00 - 10:30",
						"url": "https://www.sap.com"
					},
					{
						"Title": "Video Conference for FLP@SF, S4, Hybris",
						"Icon": "sap-icon://my-view",
						"Time": "14:00 - 15:30",
						"url": "https://www.sap.com"
					},
					{
						"Title": "Call 'Project Nimbus'",
						"Icon": "sap-icon://outgoing-call",
						"Time": "16:00 - 16:30"
					}
				]
			},
			"item": {
				"dateTime": {
					"value": "{Time}"
				},
				"description": {
					"value": "{Description}"
				},
				"title": {
					"value": "{Title}"
				},
				"icon": {
					"src": "{Icon}"
				},
				"actions": [
					{
						"type": "Navigation",
						"enabled": "{= ${url}}",
						"parameters": {
							"url": "{url}"
						}
					}
				]
			}
		}
	}
}
