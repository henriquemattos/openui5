{
	"sap.app": {
		"id": "cardsdemo.navigationAction.list",
		"type": "card"
	},
	"sap.card": {
		"type": "List",
		"header": {
			"title": "Navigation Action - List Card",
			"subtitle": "Header and item actions",
			"icon": {
				"src": "sap-icon://accept"
			},
			"status": {
				"text": "100 of 200"
			},
			"actions": [
				{
					"type": "Navigation",
					"parameters": {
						"url": "https://www.sap.com"
					}
				}
			]
		},
		"content": {
			"data": {
				"request": {
					"url": "./items.json"
				}
			},
			"item": {
				"icon": {
					"src": "{icon}"
				},
				"title": {
					"value": "{Name}"
				},
				"description": {
					"value": "{Description}"
				},
				"actions": [
					{
						"type": "Navigation",
						"enabled": "{= ${url} !== ''}",
						"parameters": {
							"url": "{url}"
						}
					}
				]
			}
		}
	}
}
