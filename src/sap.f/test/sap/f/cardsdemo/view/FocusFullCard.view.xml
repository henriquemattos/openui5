<mvc:View
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:w="sap.ui.integration.widgets"
	displayBlock="true">

	<Page title="{i18n>appTitle}">
		<subHeader>
			<Toolbar>
				<ToolbarSpacer />
				<Title text="Focus Over the Full Card" />
				<ToolbarSpacer />
			</Toolbar>
		</subHeader>
		<mvc:View viewName="sap.f.cardsdemo.view.common.CommonCardSettings" type="XML" async="true"></mvc:View>

		<Panel>
			<w:Card
				id="card1"
				manifest="{cardsPlayground>/playgroundBaseUrl}/cardcontent/objectcontent/navigation.json"
				class="sapUiMediumMargin sapFCardFocusFullCard"
				width="400px" />
			<w:Card
				id="card2"
				manifest="{listContentManifests>/tasksContent}"
				baseUrl="{cardsPlayground>/playgroundBaseUrl}"
				class="sapUiMediumMargin sapFCardFocusFullCard"
				width="400px" />
			<w:Card
				id="card3"
				manifest="{cardsPlayground>/playgroundBaseUrl}cardcontent/pagination/oDataManifest.json"
				class="sapUiMediumMargin sapFCardFocusFullCard"
				width="400px" />
			<w:Card
				id="card4"
				manifest="{cardsPlayground>/playgroundBaseUrl}/cardcontent/cardActions/analyticalNavigation.json"
				class="sapUiMediumMargin sapFCardFocusFullCard"
				width="400px" />
		</Panel>
	</Page>
</mvc:View>