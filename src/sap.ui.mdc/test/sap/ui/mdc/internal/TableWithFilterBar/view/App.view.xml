<mvc:View controllerName="sap.ui.v4demo.controller.App"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:tnt="sap.tnt">
	<tnt:ToolHeader id="app-Header">
		<IconTabHeader selectedKey="{app>/routeName}" id="iconTabHeader" select=".onNavigate">
			<items>
				<IconTabFilter id="booksTab" key="books" text="Manage Books" />
				<IconTabFilter id="ordersTab" key="orders" text="Manage Orders" />
				<IconTabFilter id="authorsTab" key="authors" text="Manage Authors"/>
			</items>
		</IconTabHeader>
		<ToolbarSpacer />
		<ToggleButton id="ToggleRTA" text="RTA" icon="sap-icon://user-edit" type="Emphasized" press=".onStartRTA" />
	</tnt:ToolHeader>
	<App id="app">
	</App>
</mvc:View>
